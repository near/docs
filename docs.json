{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "NEAR Docs",
  "colors": {
    "primary": "#1fb858",
    "light": "#1fb858",
    "dark": "#1fb858"
  },
  "logo": {
    "light": "/assets/logo.svg",
    "dark": "/assets/logo_rev.svg"
  },
  "icons": {
    "library": "lucide"
  },
  "fonts": {
    "family": "Inter"
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "search": {
    "prompt": "Search docs..."
  },
  "contextual": {
    "options": [
      "copy",
      "claude",
      "cursor"
    ]
  },
  "interaction": {
    "drilldown": true
  },
  "favicon": "assets/favicon.svg",
  "api": {
    "openapi": "/openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": [
        "bash",
        "javascript",
        "python"
      ],
      "defaults": "all"
    }
  },
  "redirects": [
    {
      "source": "/protocol/access-keys",
      "destination": "/protocol/accounts-contracts/access-keys"
    },
    {
      "source": "/ai/shade-agents",
      "destination": "/ai/shade-agents/getting-started/introduction"
    },
    {
      "source": "/ai/shade-agents/",
      "destination": "/ai/shade-agents/getting-started/introduction"
    },
    {
      "source": "/ai/shade-agents/:path*",
      "destination": "/ai/shade-agents/getting-started/introduction"
    },
    {
      "source": "/chain-abstraction/meta-transactions",
      "destination": "/protocol/transactions/meta-tx"
    }
  ]
}