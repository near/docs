          "anchor": "Explorers",
          "href": "https://explorer.near.org/",
          "icon": "search"
        },
        {
          "anchor": "Wallets",
          "href": "https://wallet.near.org",
          "icon": "wallet"
        },
        {
          "anchor": "NEAR Catalog",
          "href": "https://nearcatalog.xyz/",
          "icon": "layout-grid"
        }
      ]
    },
